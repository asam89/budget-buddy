# Database encryption passphrase (generate with: python -c "import secrets; print(secrets.token_hex(32))")
DB_PASSPHRASE=change-me-to-a-random-secret

# App secret key for session cookies
SECRET_KEY=change-me-to-another-random-secret

# Plaid API credentials — sign up at https://dashboard.plaid.com/
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Anthropic API key (for AI statement parsing) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server binding
HOST=0.0.0.0
PORT=8000
