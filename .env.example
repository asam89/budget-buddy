# Plaid API credentials — sign up at https://dashboard.plaid.com/
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# App secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# Database (default: local SQLite)
DATABASE_URL=sqlite:///./data/budget_buddy.db
